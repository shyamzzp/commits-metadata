# GitHub personal access token (read-only `repo`/`public_repo` is enough for public repos)
GITHUB_TOKEN=

# Optional: webhook secret for verifying GitHub webhook payloads
GITHUB_WEBHOOK_SECRET=

# Optional LLM analyzer toggle (rule engine always runs; LLM is additive)
ENABLE_LLM_ANALYZER=false

# GitHub API base (override for GitHub Enterprise)
GITHUB_API_BASE=https://api.github.com
